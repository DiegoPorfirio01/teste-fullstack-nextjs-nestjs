# API (obrigatório) - URL da API NestJS (ex: porta 3001 se Next.js usa 3000)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Sentry (opcional para desenvolvimento local)
# Configure via variáveis de ambiente em CI/CD — nunca commite SENTRY_AUTH_TOKEN
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx   # DSN público (browser/client)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx               # DSN privado (server/edge)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token                       # Secret: use apenas em CI/CD
